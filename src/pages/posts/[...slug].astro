---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.md$/, "") },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);

const fmt = (d: Date) =>
  `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, "0")}-${String(
    d.getDate(),
  ).padStart(2, "0")}`;
---

<BaseLayout
  title={`${post.data.title} — toshiki`}
  description={post.data.summary}
  ogType="article"
  publishedTime={post.data.date.toISOString()}
>
  <article class="post" data-pagefind-body>
    <header class="post-head">
      <h1>{post.data.title}</h1>
      <p class="meta">
        <time datetime={fmt(post.data.date)}>{fmt(post.data.date)}</time>
        {post.data.source && <> · {post.data.source}</>}
        {post.data.goal && <span class="goal-badge">{post.data.goal}</span>}
      </p>
      {
        post.data.summary && (
          <p class="summary">{post.data.summary}</p>
        )
      }
      {
        post.data.tags && post.data.tags.length > 0 && (
          <ul class="tags">
            {post.data.tags.map((t) => (
              <li>#{t}</li>
            ))}
          </ul>
        )
      }
    </header>

    <div class="post-layout">
      <div class="post-body">
        <Content />
        {
          post.data.source_url && (
            <p class="source-link">
              <a href={post.data.source_url} rel="noopener" target="_blank">
                原文を読む →
              </a>
            </p>
          )
        }
      </div>

      {
        toc.length > 0 && (
          <aside class="toc">
            <p class="toc-title">目次</p>
            <ul>
              {toc.map((h) => (
                <li class={`depth-${h.depth}`}>
                  <a href={`#${h.slug}`}>{h.text}</a>
                </li>
              ))}
            </ul>
          </aside>
        )
      }
    </div>
  </article>
</BaseLayout>

<style>
  .post-head {
    margin-bottom: 2.5rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--border);
  }
  .post-head h1 {
    font-size: 2rem;
    line-height: 1.35;
    margin: 0 0 0.75rem;
  }
  .post-head .meta {
    color: var(--fg-soft);
    font-size: 0.85rem;
    margin: 0 0 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .post-head .goal-badge {
    background: var(--bg-soft);
    border: 1px solid var(--border);
    padding: 0.1rem 0.5rem;
    border-radius: 0.25rem;
    font-size: 0.75rem;
  }
  .post-head .summary {
    color: var(--fg);
    background: var(--bg-soft);
    border-left: 3px solid var(--accent);
    padding: 0.75rem 1rem;
    border-radius: 0 0.4rem 0.4rem 0;
    margin: 0 0 1rem;
    font-size: 0.95rem;
  }
  .post-head .tags {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .post-head .tags li {
    background: var(--bg-soft);
    color: var(--fg-soft);
    padding: 0.15rem 0.55rem;
    border-radius: 0.25rem;
    font-size: 0.75rem;
  }

  .post-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  @media (min-width: 960px) {
    .post-layout {
      grid-template-columns: 1fr 200px;
    }
  }

  .post-body :global(h2) {
    font-size: 1.3rem;
    margin: 2.5rem 0 0.75rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--border);
    scroll-margin-top: 1rem;
  }
  .post-body :global(h3) {
    font-size: 1.1rem;
    margin: 2rem 0 0.5rem;
    scroll-margin-top: 1rem;
  }

  .source-link {
    margin-top: 2rem;
    border-top: 1px solid var(--border);
    padding-top: 1rem;
  }

  .toc {
    font-size: 0.85rem;
    align-self: start;
  }
  @media (min-width: 960px) {
    .toc {
      position: sticky;
      top: 1.5rem;
      max-height: calc(100vh - 3rem);
      overflow-y: auto;
      border-left: 1px solid var(--border);
      padding-left: 1rem;
    }
  }
  @media (max-width: 959px) {
    .toc {
      background: var(--bg-soft);
      border: 1px solid var(--border);
      border-radius: 0.5rem;
      padding: 0.75rem 1rem;
      order: -1;
    }
  }
  .toc-title {
    color: var(--fg-soft);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 0 0 0.5rem;
  }
  .toc ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .toc li {
    margin: 0.35rem 0;
    line-height: 1.4;
  }
  .toc li.depth-3 {
    padding-left: 0.9rem;
    font-size: 0.8rem;
  }
  .toc a {
    color: var(--fg-soft);
  }
  .toc a:hover {
    color: var(--accent);
  }
</style>
