---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404 — toshiki" description="ページが見つかりません">
  <div class="not-found">
    <p class="num">404</p>
    <h2>このページは見つかりませんでした</h2>
    <p class="desc">
      URL が間違っているか、記事が削除された可能性があります。
    </p>
    <ul class="actions">
      <li><a href="/">→ トップページへ</a></li>
      <li><a href="/archive/">→ アーカイブを見る</a></li>
      <li><a href="/search/">→ 検索する</a></li>
    </ul>
  </div>
</BaseLayout>

<style>
  .not-found {
    text-align: center;
    padding: 3rem 1rem;
  }
  .num {
    font-size: 5rem;
    font-weight: 700;
    color: var(--accent);
    margin: 0;
    letter-spacing: 0.05em;
    line-height: 1;
  }
  .not-found h2 {
    font-size: 1.3rem;
    margin: 1rem 0 0.5rem;
  }
  .not-found .desc {
    color: var(--fg-soft);
    font-size: 0.9rem;
  }
  .actions {
    list-style: none;
    padding: 0;
    margin: 2rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    align-items: center;
    font-size: 0.95rem;
  }
</style>
