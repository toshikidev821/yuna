---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const GOAL_META: Record<string, { label: string; description: string }> = {
  "2": { label: "#2 体を鍛える", description: "+10kg 増量プロジェクト" },
  "3": { label: "#3 投資・資産形成", description: "運用収益で生活する" },
  "4": { label: "#4 英語", description: "中級レベルで会話できる" },
  "5": { label: "#5 たくさん人に会う", description: "月1イベント / 週1の予定" },
  "130": {
    label: "#130 エンジニアレベルアップ",
    description: "Rust + ハードウェアまで触る",
  },
  "131": { label: "#131 引越し", description: "猫が飼える家" },
};

const posts = await getCollection("posts");
const counter = new Map<string, number>();
posts.forEach((p) => {
  if (p.data.goal) {
    const key = p.data.goal.replace(/^#/, "");
    counter.set(key, (counter.get(key) ?? 0) + 1);
  }
});

const goals = Object.entries(GOAL_META).map(([key, meta]) => ({
  key,
  ...meta,
  count: counter.get(key) ?? 0,
}));
---

<BaseLayout
  title="goals — toshiki"
  description="長期目標ごとの記事アーカイブ"
>
  <h2 class="page-title">Goals</h2>
  <p class="page-lead">
    2026 年は 6 つの長期目標で生きる。各目標に紐づく記事をここから辿れます。
  </p>
  <ul class="goal-list">
    {
      goals.map((g) => (
        <li>
          <a href={`/goals/${g.key}/`}>
            <div class="goal-row">
              <span class="goal-label">{g.label}</span>
              <span class="goal-count">{g.count} 件</span>
            </div>
            <p class="goal-desc">{g.description}</p>
          </a>
        </li>
      ))
    }
  </ul>
</BaseLayout>

<style>
  .page-title {
    font-size: 1.6rem;
    margin: 0 0 0.5rem;
  }
  .page-lead {
    color: var(--fg-soft);
    font-size: 0.9rem;
    margin: 0 0 1.5rem;
  }
  .goal-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.75rem;
  }
  .goal-list a {
    display: block;
    padding: 1rem 1.2rem;
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    color: var(--fg);
  }
  .goal-list a:hover {
    border-color: var(--accent);
    text-decoration: none;
  }
  .goal-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }
  .goal-label {
    font-weight: 600;
  }
  .goal-count {
    color: var(--fg-soft);
    font-size: 0.8rem;
  }
  .goal-desc {
    color: var(--fg-soft);
    font-size: 0.85rem;
    margin: 0.3rem 0 0;
  }
</style>
