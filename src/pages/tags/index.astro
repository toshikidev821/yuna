---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const posts = await getCollection("posts");
const counter = new Map<string, number>();
posts.forEach((p) => {
  (p.data.tags ?? []).forEach((t) => {
    counter.set(t, (counter.get(t) ?? 0) + 1);
  });
});
const tags = Array.from(counter.entries()).sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="tags — toshiki" description="タグ一覧">
  <h2 class="page-title">Tags</h2>
  <ul class="tag-cloud">
    {
      tags.map(([tag, count]) => (
        <li>
          <a href={`/tags/${tag}/`}>
            #{tag} <span class="count">{count}</span>
          </a>
        </li>
      ))
    }
  </ul>
</BaseLayout>

<style>
  .page-title {
    font-size: 1.6rem;
    margin: 0 0 1.5rem;
  }
  .tag-cloud {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .tag-cloud a {
    display: inline-block;
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: 0.4rem;
    padding: 0.4rem 0.8rem;
    font-size: 0.9rem;
  }
  .tag-cloud .count {
    color: var(--fg-soft);
    font-size: 0.75rem;
    margin-left: 0.3rem;
  }
</style>
