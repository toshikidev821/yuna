---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  const tags = new Set<string>();
  posts.forEach((p) => (p.data.tags ?? []).forEach((t) => tags.add(t)));
  return Array.from(tags).map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: posts
        .filter((p) => (p.data.tags ?? []).includes(tag))
        .sort((a, b) => b.data.date.getTime() - a.data.date.getTime()),
    },
  }));
}

const { tag, posts } = Astro.props;

const fmt = (d: Date) =>
  `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, "0")}-${String(
    d.getDate(),
  ).padStart(2, "0")}`;
---

<BaseLayout
  title={`#${tag} — toshiki`}
  description={`タグ「${tag}」の記事一覧`}
>
  <p class="crumb"><a href="/tags/">← すべてのタグ</a></p>
  <h2 class="tag-title">#{tag}</h2>
  <p class="count">{posts.length} 件</p>
  <ul class="post-list">
    {
      posts.map((post) => (
        <li>
          <time datetime={fmt(post.data.date)}>{fmt(post.data.date)}</time>
          <a href={`/posts/${post.id.replace(/\.md$/, "")}/`}>
            {post.data.title}
          </a>
          {post.data.goal && <span class="goal">{post.data.goal}</span>}
        </li>
      ))
    }
  </ul>
</BaseLayout>

<style>
  .crumb {
    font-size: 0.85rem;
    color: var(--fg-soft);
    margin: 0 0 1rem;
  }
  .tag-title {
    font-size: 1.6rem;
    margin: 0 0 0.25rem;
  }
  .count {
    color: var(--fg-soft);
    font-size: 0.85rem;
    margin: 0 0 1.5rem;
  }
</style>
